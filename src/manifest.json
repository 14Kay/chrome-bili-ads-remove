{
  "manifest_version": 3,
  "name": "bilibili Ads Remover",
  "version": "2.0.0",
  "description": "bilibili插件，屏蔽首页换一换广告、动态广告(关键词匹配)",
  "icons": {
    "16": "assets/image/icon16.png",
    "32": "assets/image/icon32.png",
    "48": "assets/image/icon48.png",
    "128": "assets/image/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": "assets/image/icon128.png"
  },
  "content_scripts": [
    {
      "js": [
        "src/content/dynamic.ts"
      ],
      "matches": [
        "https://t.bilibili.com/*"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
        "src/content/injected/dynamic.ts"
      ],
      "matches": [
        "https://t.bilibili.com/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "js": [
        "src/content/injected/index.ts"
      ],
      "css": [
        "assets/style/injected.css"
      ],
      "matches": [
        "https://bilibili.com/*",
        "https://www.bilibili.com/*"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "css": [
        "assets/style/ads.css"
      ],
      "matches": [
        "https://*.bilibili.com/*"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
        "src/content/index_init.ts"
      ],
      "matches": [
        "https://bilibili.com/*",
        "https://www.bilibili.com/*"
      ],
      "run_at": "document_end"
    },
    {
      "js": [
        "src/content/video.ts"
      ],
      "matches": [
        "https://www.bilibili.com/video/*"
      ],
      "run_at": "document_end"
    }
  ],
  "author": "rsndm.14k@gmail.com",
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/injected/*.ts"
      ],
      "matches": [
        "https://bilibili.com/*",
        "https://www.bilibili.com/*"
      ]
    }
  ]
}